{
  "name": "transformacion-90",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app": "npm run build && electron .",
    "icon": "node scripts/make-icon.mjs",
    "app:pack": "npm run build && electron-packager . Transformacion --platform=win32 --arch=x64 --out=release --overwrite --icon=build/icon.ico --ignore=node_modules --ignore=\"/src\" --ignore=\"/release\" --ignore=\"/public\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.11",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.emmanuel.transformacion",
    "productName": "Transformacion",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Transformacion"
    }
  }
}
